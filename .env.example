# =============================================================================
# Bagcoin - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values
# =============================================================================

# --- Groq AI (Required) ---
GROQ_API_KEY=your_groq_api_key_here

# --- Tavily Search (Optional) ---
TAVILY_API_KEY=your_tavily_api_key_here

# --- Database (Required) ---
# For local dev with docker-compose:
DATABASE_URL=postgresql://bagcoin:bagcoinpg@db:5432/bagcoin_db

# --- Redis (Required) ---
# For local dev with docker-compose:
REDIS_URL=redis://redis:6379/0

# --- WhatsApp Bridge (Required) ---
# For local dev with docker-compose:
WHATSAPP_BRIDGE_URL=http://whatsapp:3002

# --- Security (Required) ---
SECRET_KEY=your_secret_key_here_change_in_production

# --- Web Frontend (Required for web) ---
NEXT_PUBLIC_API_URL=http://localhost:8001

# --- MongoDB (Required for WhatsApp session persistence) ---
MONGO_USER=bagcoin
MONGO_PASSWORD=bagcoinmongo

# --- PostgreSQL (Required for docker-compose) ---
POSTGRES_USER=bagcoin
POSTGRES_PASSWORD=bagcoinpg
POSTGRES_DB=bagcoin_db


