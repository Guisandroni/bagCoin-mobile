# =============================================================================
# Bagcoin - Variaveis de Ambiente
# =============================================================================

# -----------------------------------------------------------------------------
# Banco de Dados
# -----------------------------------------------------------------------------
POSTGRES_USER=user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=finance_db

# -----------------------------------------------------------------------------
# MongoDB (sessoes WhatsApp)
# -----------------------------------------------------------------------------
MONGO_USER=admin
MONGO_PASSWORD=changeme

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# Usado pelo Celery para filas e cache
# (nao precisa de usuario/senha no ambiente local)

# -----------------------------------------------------------------------------
# API Keys
# -----------------------------------------------------------------------------
GROQ_API_KEY=sua_chave_aqui
TAVILY_API_KEY=sua_chave_aqui_opcional

# -----------------------------------------------------------------------------
# Seguranca
# -----------------------------------------------------------------------------
SECRET_KEY=uma_chave_secreta_forte_aqui
JWT_SECRET=uma_chave_jwt_secreta_aqui

# -----------------------------------------------------------------------------
# Google OAuth
# -----------------------------------------------------------------------------
# Crie credenciais em https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=seu_client_id_aqui
GOOGLE_CLIENT_SECRET=seu_client_secret_aqui

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8001

# -----------------------------------------------------------------------------
# Deploy (Docker Hub)
# -----------------------------------------------------------------------------
DOCKERHUB_USER=seu_usuario_dockerhub
