# =============================================================================
# Bagcoin - Variaveis de Ambiente
# =============================================================================

# -----------------------------------------------------------------------------
# Banco de Dados
# -----------------------------------------------------------------------------
POSTGRES_USER=user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=finance_db

# -----------------------------------------------------------------------------
# MongoDB (sessoes WhatsApp)
# -----------------------------------------------------------------------------
MONGO_USER=admin
MONGO_PASSWORD=changeme

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# Usado pelo Celery para filas e cache
# (nao precisa de usuario/senha no ambiente local)

# -----------------------------------------------------------------------------
# API Keys
# -----------------------------------------------------------------------------
GROQ_API_KEY=sua_chave_aqui
TAVILY_API_KEY=sua_chave_aqui_opcional

# -----------------------------------------------------------------------------
# Seguranca
# -----------------------------------------------------------------------------
SECRET_KEY=uma_chave_secreta_forte_aqui

# -----------------------------------------------------------------------------
# Deploy (Docker Hub)
# -----------------------------------------------------------------------------
DOCKERHUB_USER=seu_usuario_dockerhub

# -----------------------------------------------------------------------------
# Web (URL publica da API)
# -----------------------------------------------------------------------------
# Em producao com nginx, use a URL publica do seu dominio
# Exemplo: https://bagcoin.seudominio.com
NEXT_PUBLIC_API_URL=http://localhost
