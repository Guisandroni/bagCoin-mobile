
CONTAINER_PREFIX=bagcoin_api

# === Domain Configuration ===
# IMPORTANT: substitua example.com pelo seu domínio REAL antes do deploy
DOMAIN=example.com
ACME_EMAIL=admin@example.com
CORS_ORIGINS=["https://example.com","https://api.example.com"]
INTERNAL_API_BASE_URL=http://app:8000

# === PostgreSQL ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-generate-with-openssl-rand-base64-32
POSTGRES_DB=bagcoin_api

# === Redis ===
REDIS_PASSWORD=change-me-generate-with-openssl-rand-base64-32

# === JWT Secret ===
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# === API / Bridges ===
API_KEY=change-me-generate-with-openssl-rand-hex-32
WHATSAPP_API_KEY=change-me-generate-with-openssl-rand-hex-32
WHATSAPP_BRIDGE_URL=http://whatsapp-bridge:3001
TELEGRAM_BOT_TOKEN=
BOT_TELEGRAM_USERNAME=
BOT_WHATSAPP_NUMBER=

# === Traefik Dashboard ===
# Generate with: htpasswd -nb admin yourpassword
# Example: admin:$apr1$xyz$hash
TRAEFIK_DASHBOARD_AUTH=

# === Flower Monitoring ===
FLOWER_USER=admin
FLOWER_PASSWORD=change-me-generate-with-openssl-rand-base64-16

# === LLM Providers ===
DEFAULT_LLM_MODEL=deepseek-v4-flash
GROQ_API_KEY=
OPENCODE_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
GEMINI_API_KEY=
TAVILY_API_KEY=

# === Google OAuth ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# === Email Verification Delivery ===
# Prefer Resend in production. Keep smtp only for fallback/manual setup.
EMAIL_PROVIDER=resend_api
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_API_BASE_URL=https://api.resend.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# === Agent Runtime ===
TIMEZONE=America/Sao_Paulo
HUMANIZE_RESPONSES=true
HUMANIZE_MAX_CHARS=900
HUMANIZE_ALLOWED_INTENTS_EXTRA=[]
ECHO_AUDIO_TRANSCRIPTION=true
IMAGE_STRUCTURED_EXTRACT=true
LLM_EXTRACT_TIMEOUT=3
EXTRA_WHISPER_HALLUCINATIONS=[]
