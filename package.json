{
  "name": "bagcoin",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "@types/bun": "^1.3.4",
      "elysia": "^1.4.21",
      "@trpc/server": "^11.7.2",
      "better-auth": "^1.4.9",
      "@trpc/client": "^11.7.2",
      "@better-auth/expo": "^1.4.9",
      "drizzle-orm": "^0.45.1"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @bagcoin/db db:push",
    "db:studio": "turbo -F @bagcoin/db db:studio",
    "db:generate": "turbo -F @bagcoin/db db:generate",
    "db:migrate": "turbo -F @bagcoin/db db:migrate",
    "db:local": "turbo -F @bagcoin/db db:local",
    "check": "biome check --write ."
  },
  "dependencies": {
    "@bagcoin/env": "workspace:*",
    "@sinclair/typebox": "^0.34.48",
    "dotenv": "^17.2.3",
    "latest": "^0.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@bagcoin/config": "workspace:*",
    "@biomejs/biome": "^2.3.13",
    "@types/bun": "^1.3.6",
    "turbo": "^2.7.6",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.6"
}
